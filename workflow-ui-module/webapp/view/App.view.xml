<mvc:View controllerName="workflownew.workflowuimodule.controller.App"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"  xmlns:table="sap.ui.table">
    <App>
        <pages>
            <Page title="Employee Details">

                <content>

                    <!-- Tree Table -->
                    <table:TreeTable
                        id="treeTable"
                        rows="{
                            path: 'mTreeTable>/nodes',
                            parameters: {
                                arrayNames: ['children']
                            }
                        }"
                        visibleRowCount="10"
                        width="100%"
                        selectionMode="MultiToggle"
                        rowSelectionChange="onRowSelection">

                        <table:columns>

                            <table:Column width="250px">
                                <Label text="Skill" />
                                <table:template>
                                    <Text text="{mTreeTable>skill}" />
                                </table:template>
                            </table:Column>

                            <table:Column width="200px">
                                <Label text="Years of Experience" />
                                <table:template>
                                    <Text text="{mTreeTable>yearsOfExperience}" />
                                </table:template>
                            </table:Column>

                            <table:Column width="200px">
                                <Label text="Name" />
                                <table:template>
                                    <Text text="{mTreeTable>name}" />
                                </table:template>
                            </table:Column>

                            <table:Column width="200px">
                                <Label text="Email" />
                                <table:template>
                                    <Text text="{mTreeTable>email}" />
                                </table:template>
                            </table:Column>

                            <table:Column width="200px">
                                <Label text="Reviewer" />
                                <table:template>
                                    <Text text="{mTreeTable>reviewer}" />
                                </table:template>
                            </table:Column>

                            <table:Column width="200px">
                                <Label text="Comments" />
                                <table:template>
                                    <Text text="{mTreeTable>comments}" />
                                </table:template>
                            </table:Column>

                        </table:columns>

                    </table:TreeTable>

                    <!-- Employee Form -->
                    <form:SimpleForm
                        id="employeeForm"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        width="100%">

                        <form:content>

                            <!-- Name -->
                            <Label text="Name" />
                            <Input
                                value="{context>/name}"
                                placeholder="Enter Name" />

                            <!-- Email -->
                            <Label text="Email" />
                            <Input
                                value="{context>/email}"
                                placeholder="Enter Email" />

                            <!-- Skills -->
                            <Label text="Skills" />
                            <MultiComboBox
                                selectedKeys="{context>/skills}"
                                width="100%">

                                <core:Item key="Javascript" text="Javascript" />
                                <core:Item key="UI5" text="UI5" />
                                <core:Item key="Vue.js" text="Vue.js" />
                                <core:Item key="Java" text="Java" />
                                <core:Item key="Python" text="Python" />

                            </MultiComboBox>

                            <!-- Years of Experience -->
                            <Label text="Years of Experience" />
                            <Input
                                type="Number"
                                value="{context>/yearsOfExperience}"
                                placeholder="Enter Years of Experience" />

                            <!-- Comments -->
                            <Label text="Comments" />
                            <TextArea
                                value="{context>/comments}"
                                rows="4"
                                placeholder="Enter Comments" />

                            <!-- Reviewer Comments -->
                            <Label text="Reviewer Comments" />
                            <TextArea
                                value="{context>/reviewerComments}"
                                rows="4"
                                placeholder="Enter Reviewer Comments" />

                        </form:content>

                    </form:SimpleForm>

                </content>

            </Page>
        </pages>
    </App>
</mvc:View>
